APP_DEBUG=true

DB_DRIVER=sqlite
DB_PATH=/path/to/database.sqlite

# MySQL / PostgreSQL (uncomment and fill in if not using SQLite)
#DB_HOST=localhost
#DB_PORT=3306
#DB_DATABASE=pointstart
#DB_USERNAME=root
#DB_PASSWORD=
#DB_CHARSET=utf8mb4

# CORS — disabled by default, opt-in for backend development
#CORS_ENABLED=false
#CORS_ALLOWED_ORIGINS=*
#CORS_ALLOWED_METHODS=GET,POST,OPTIONS
#CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
#CORS_ALLOW_CREDENTIALS=false
#CORS_MAX_AGE=86400

# CSRF — enabled by default, protects HTML form POST requests
#CSRF_ENABLED=true

# Updater — disabled by default, enable to allow framework updates via /pointart/update
#UPDATER_ENABLED=false
#UPDATER_SECRET=
